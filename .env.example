# LLM provider API key (required)
API_KEY=sk-ant-...

# Provider: anthropic | openrouter | openai | ollama  (default: anthropic)
PROVIDER=anthropic

# Model override — comment out to use the provider default
# ZEROCLAW_MODEL=claude-sonnet-4-6

# Camera connection (defaults match camera_config.ini)
CAMERA_IP=192.168.0.100
CAMERA_PORT=80
CAMERA_USERNAME=admin
CAMERA_PASSWORD=admin
